<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="conecte_crie.Views.CadastroProdutoPage"
             Title="Cadastro de Produto">

    <VerticalStackLayout Padding="20" Spacing="15">

        <Entry x:Name="txtNome" Placeholder="Nome do produto" />
        <Entry x:Name="txtDescricao" Placeholder="Descrição do produto" />
        <Entry x:Name="txtPreco" Placeholder="Preço" Keyboard="Numeric"/>

        <Button Text="Salvar Produto" Clicked="OnSalvarClicked" />

    </VerticalStackLayout>

</ContentPage>