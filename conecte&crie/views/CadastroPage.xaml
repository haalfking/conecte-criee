<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="conecte_crie.Views.CadastroPage"
             Title="Cadastro">

    <VerticalStackLayout Padding="30" Spacing="15">

        <Label Text="Cadastro de Usuário"
               FontSize="22"
               HorizontalOptions="Center"/>

        <Entry x:Name="txtNome" Placeholder="Nome" />
        <Entry x:Name="txtEmail" Placeholder="Email" />
        <Entry x:Name="txtSenha" Placeholder="Senha" IsPassword="True"/>

        <Button Text="Salvar"
                Clicked="OnSalvarClicked"/>

    </VerticalStackLayout>

</ContentPage>